# Firebase Config
# Firebase Console → Project Settings → General → এখান থেকে পাবেন
NEXT_PUBLIC_FIREBASE_API_KEY=আপনার_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=আপনার_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=আপনার_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=আপনার_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=আপনার_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=আপনার_app_id
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://আপনার_project-default-rtdb.firebaseio.com

# Cloudinary — একাউন্ট ১
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME_1=cloud_name_1
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_1=preset_1

# Cloudinary — একাউন্ট ২
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME_2=cloud_name_2
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_2=preset_2

# Cloudinary — একাউন্ট ৩
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME_3=cloud_name_3
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_3=preset_3

# Cloudinary — একাউন্ট ৪
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME_4=cloud_name_4
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_4=preset_4
